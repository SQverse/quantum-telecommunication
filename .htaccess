RewriteEngine On

# 1. Paksa koneksi ke HTTPS (Biar Aman/SSL)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Menghilangkan ekstensi .php dari URL
# Jadi domain.com/kontak.php bisa diakses lewat domain.com/kontak
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# 3. Menghilangkan ekstensi .html dari URL
# Jadi domain.com/about.html bisa diakses lewat domain.com/about
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# 4. Mencegah orang liat-liat isi folder (Security)
DirectoryIndex index.php index.html
Options -Indexes

# Force Remove .html extension
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ /$1 [R=301,L]